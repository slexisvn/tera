{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Tera",
  "scopeName": "source.tera",
  "fileTypes": [
    "tera"
  ],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#declarations"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#builtins"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.tera",
          "match": "#.*$"
        },
        {
          "name": "comment.line.double-slash.tera",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.tera",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.tera",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.tera",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.tera",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.tera",
          "match": "\\b\\d+(\\.\\d+)?([eE][+-]?\\d+)?\\b"
        },
        {
          "name": "constant.numeric.tera",
          "match": "\\.\\d+([eE][+-]?\\d+)?\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.other.declaration.tera",
          "match": "\\b(?:fn|forward|model|optimizer|train|validate)\\b"
        },
        {
          "name": "keyword.control.tera",
          "match": "\\b(?:break|continue|else|for|if|in|return|while)\\b"
        },
        {
          "name": "keyword.operator.logical.tera",
          "match": "\\b(?:and|not|or)\\b"
        },
        {
          "name": "constant.language.tera",
          "match": "\\b(?:false|null|true)\\b"
        },
        {
          "name": "storage.type.tera",
          "match": "\\b(?:Record|Tensor|boolean|float|int|none|string)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.compound.tera",
          "match": "\\*\\*=|\\*\\*|==|!=|<=|>=|\\+=|-=|\\*=|/=|%=|@=|->"
        },
        {
          "name": "keyword.operator.tera",
          "match": "=|:|\\+|-|\\*|/|%|@|<|>|\\{|\\}|\\|"
        },
        {
          "name": "punctuation.separator.tera",
          "match": "[,.]"
        },
        {
          "name": "punctuation.section.brackets.tera",
          "match": "[\\[\\]()]"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.class.metric.tera",
          "match": "\\b(?:Accuracy|ConfusionMatrix|F1Score|MetricCollection|Precision|Recall)\\b"
        },
        {
          "name": "support.function.tera",
          "match": "\\b(?:accuracy_score|confusion_matrix|mean_absolute_error|mean_squared_error|r2_score)\\b"
        },
        {
          "name": "support.function.tera",
          "match": "\\b(?:acf|durbin_watson|ljung_box|pacf|periodogram)\\b"
        },
        {
          "name": "support.class.optimizer.tera",
          "match": "\\b(?:Adam|AdamW|SGD)\\b"
        },
        {
          "name": "support.class.nn-module.tera",
          "match": "\\b(?:AdaptiveAvgPool2d|AvgPool2d|BatchNorm1d|BatchNorm2d|BCELoss|Conv1d|Conv2d|CrossEntropyLoss|Dropout|ELU|Embedding|Flatten|GELU|GRU|GRUCell|LayerNorm|LeakyReLU|Linear|LogSoftmax|LSTM|LSTMCell|MaxPool2d|MSELoss|NLLLoss|ReLU|Sigmoid|SiLU|Softmax|Tanh)\\b"
        },
        {
          "name": "support.function.tera",
          "match": "\\b(?:adf_test|amihud|backtest|bsadf|cross_sectional|cusum_events|deflated_sharpe|dollar_bars|dynamic_beta|engle_granger|equal_weight|fit_garch|garch_forecast|garch_volatility|half_life|hrp|hurst_exponent|johansen|kalman_filter|kalman_smoother|kpss_test|kyle_lambda|load_quill|long_short|mean_reversion|mean_variance|min_track_record_length|momentum|pbo|quill|risk_parity|roll_spread|sadf|sharpe|tick_bars|tick_rule|volume_bars|vpin|walk_forward|zscore)\\b"
        },
        {
          "name": "support.function.tera",
          "match": "\\b(?:anderson_darling|chi2_gof|chi2_independence|dagostino_k2|jarque_bera|ks_test_1samp|ks_test_2samp|mann_whitney_u|t_test_1samp|t_test_ind|t_test_paired)\\b"
        },
        {
          "name": "support.function.factory.tera",
          "match": "\\b(?:arange|empty|emptyLike|eye|full|fullLike|linspace|ones|onesLike|randn|randnLike|randperm|tensor|zeros|zerosLike)\\b"
        },
        {
          "name": "support.function.tera",
          "match": "\\b(?:avg|col|count|countStar|expr|lit|max|min|sum|name)\\b"
        },
        {
          "name": "constant.language.dtype.tera",
          "match": "\\b(?:bool|f16|f32|f64|i32|i64)\\b"
        },
        {
          "name": "support.function.tera",
          "match": "\\b(?:cat|load_json|load_model|load_tokenizer|read_text|stack|Tokenizer|where)\\b"
        },
        {
          "name": "support.function.tera",
          "match": "\\b(?:chi2_cdf|chi2_pdf|chi2_ppf|f_cdf|f_pdf|f_ppf|normal_cdf|normal_pdf|normal_ppf|t_cdf|t_pdf|t_ppf)\\b"
        },
        {
          "name": "support.function.tera",
          "match": "\\b(?:cholesky|cov|det|eigh|inv|lstsq|pinv|solve|svd)\\b"
        },
        {
          "name": "support.function.utility.tera",
          "match": "\\b(?:compile|graph|optim_config|print|range|trace)\\b"
        },
        {
          "name": "support.class.logger.tera",
          "match": "\\b(?:ConsoleLogger|CSVLogger)\\b"
        },
        {
          "name": "support.function.tera",
          "match": "\\b(?:convolve|correlate|polyfit|polyroots|polyval|rolling_max|rolling_mean|rolling_min|rolling_std|rolling_sum)\\b"
        },
        {
          "name": "support.class.scheduler.tera",
          "match": "\\b(?:CosineAnnealingLR|ReduceLROnPlateau|StepLR)\\b"
        },
        {
          "name": "constant.language.device.tera",
          "match": "\\b(?:cpu|gpu|wasm|webgpu)\\b"
        },
        {
          "name": "support.function.tera",
          "match": "\\b(?:cross_val_score|train_test_split)\\b"
        },
        {
          "name": "support.function.tera",
          "match": "\\b(?:cubic_spline|erf|erfc|gamma|lgamma|linear_interp)\\b"
        },
        {
          "name": "support.function.data.tera",
          "match": "\\b(?:DataFrame|DataLoader|load_csv|TensorDataset)\\b"
        },
        {
          "name": "support.function.tera",
          "match": "\\b(?:DecisionTreeClassifier|DecisionTreeRegressor|ElasticNet|GaussianNB|GradientBoostingClassifier|GradientBoostingRegressor|KNeighborsClassifier|KNeighborsRegressor|Lasso|LinearRegression|LogisticRegression|RandomForestClassifier|RandomForestRegressor|Ridge)\\b"
        },
        {
          "name": "support.class.callback.tera",
          "match": "\\b(?:EarlyStopping|GradientAccumulationScheduler|LearningRateMonitor|ModelCheckpoint|ProgressCallback|Timer)\\b"
        },
        {
          "name": "support.function.tera",
          "match": "\\b(?:fft|ifft|qr)\\b"
        },
        {
          "name": "support.function.tera",
          "match": "\\b(?:GridSearchCV)\\b"
        },
        {
          "name": "support.function.tera",
          "match": "\\b(?:KFold|TimeSeriesSplit)\\b"
        },
        {
          "name": "support.function.tera",
          "match": "\\b(?:KMeans)\\b"
        },
        {
          "name": "support.function.tera",
          "match": "\\b(?:LabelEncoder|MinMaxScaler|OneHotEncoder|PCA|StandardScaler)\\b"
        },
        {
          "name": "support.function.tera",
          "match": "\\b(?:multivariate_normal|random_chi2|random_exponential|random_normal|random_t|random_uniform)\\b"
        },
        {
          "name": "support.class.sequential.tera",
          "match": "\\b(?:Sequential)\\b"
        },
        {
          "name": "support.class.trainer.tera",
          "match": "\\b(?:Trainer)\\b"
        },
        {
          "name": "support.function.tera",
          "match": "\\b(?:log)\\b"
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "match": "\\b(model|fn)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.other.declaration.tera"
            },
            "2": {
              "name": "entity.name.type.tera"
            }
          }
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.tera",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
        }
      ]
    }
  }
}
