{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Tera",
  "scopeName": "source.tera",
  "fileTypes": [
    "tera"
  ],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#regex"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#declarations"
    },
    {
      "include": "#annotations"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#builtins"
    },
    {
      "include": "#calls"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.tera",
          "match": "#.*$"
        },
        {
          "name": "comment.line.double-slash.tera",
          "match": "//.*$"
        },
        {
          "name": "comment.block.tera",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.tera",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.tera",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.tera",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.tera",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.template.tera",
          "begin": "`",
          "end": "`",
          "patterns": [
            {
              "name": "constant.character.escape.tera",
              "match": "\\\\."
            },
            {
              "name": "meta.template.expression.tera",
              "begin": "\\$\\{",
              "end": "\\}",
              "beginCaptures": {
                "0": {
                  "name": "punctuation.definition.template-expression.begin.tera"
                }
              },
              "endCaptures": {
                "0": {
                  "name": "punctuation.definition.template-expression.end.tera"
                }
              },
              "patterns": [
                {
                  "include": "$self"
                }
              ]
            }
          ]
        }
      ]
    },
    "regex": {
      "patterns": [
        {
          "match": "(=|==|===|!=|!==|=>|\\+=|-=|\\*=|/=|%=)\\s*(/(?![/*])(?:[^/\\\\\\[\\n]|\\\\.|\\[(?:[^\\]\\\\\\n]|\\\\.)*\\])+/[gimsuyd]*)",
          "captures": {
            "1": {
              "name": "keyword.operator.tera"
            },
            "2": {
              "name": "string.regexp.tera"
            }
          }
        },
        {
          "match": "([(\\[,:])\\s*(/(?![/*])(?:[^/\\\\\\[\\n]|\\\\.|\\[(?:[^\\]\\\\\\n]|\\\\.)*\\])+/[gimsuyd]*)",
          "captures": {
            "1": {
              "name": "punctuation.separator.tera"
            },
            "2": {
              "name": "string.regexp.tera"
            }
          }
        },
        {
          "match": "\\b(return|and|or|not|in|of|typeof|await|yield)\\b\\s*(/(?![/*])(?:[^/\\\\\\[\\n]|\\\\.|\\[(?:[^\\]\\\\\\n]|\\\\.)*\\])+/[gimsuyd]*)",
          "captures": {
            "1": {
              "name": "keyword.control.tera"
            },
            "2": {
              "name": "string.regexp.tera"
            }
          }
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.tera",
          "match": "\\b0[xX][0-9a-fA-F][0-9a-fA-F_]*\\b"
        },
        {
          "name": "constant.numeric.binary.tera",
          "match": "\\b0[bB][01][01_]*\\b"
        },
        {
          "name": "constant.numeric.octal.tera",
          "match": "\\b0[oO][0-7][0-7_]*\\b"
        },
        {
          "name": "constant.numeric.decimal.tera",
          "match": "\\b\\d[\\d_]*(?:\\.[\\d_]+)?(?:[eE][+-]?\\d+)?\\b"
        },
        {
          "name": "constant.numeric.decimal.tera",
          "match": "(?<![\\w.])\\.\\d[\\d_]*(?:[eE][+-]?\\d+)?\\b"
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "match": "\\b(fn|function)\\s+([A-Za-z_$][A-Za-z0-9_$]*)",
          "captures": {
            "1": {
              "name": "keyword.other.declaration.tera"
            },
            "2": {
              "name": "entity.name.function.tera"
            }
          }
        },
        {
          "match": "\\b(model|class)\\s+([A-Za-z_$][A-Za-z0-9_$]*)",
          "captures": {
            "1": {
              "name": "keyword.other.declaration.tera"
            },
            "2": {
              "name": "entity.name.type.tera"
            }
          }
        },
        {
          "match": "\\b(extends)\\s+([A-Za-z_$][A-Za-z0-9_$]*)",
          "captures": {
            "1": {
              "name": "keyword.other.declaration.tera"
            },
            "2": {
              "name": "entity.other.inherited-class.tera"
            }
          }
        }
      ]
    },
    "annotations": {
      "patterns": [
        {
          "match": "(->)\\s*(?!(?:instanceof|undefined|continue|function|default|extends|finally|delete|return|switch|typeof|async|await|break|catch|class|const|false|model|super|throw|while|yield|case|else|null|this|true|void|and|for|let|new|not|try|var|do|fn|if|in|of|or)\\b)([A-Za-z_$][A-Za-z0-9_$]*)",
          "captures": {
            "1": {
              "name": "keyword.operator.arrow.tera"
            },
            "2": {
              "name": "entity.name.type.tera"
            }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.other.declaration.tera",
          "match": "\\b(?:function|extends|class|const|model|let|var|fn)\\b"
        },
        {
          "name": "keyword.control.tera",
          "match": "\\b(?:continue|default|finally|return|switch|async|await|break|catch|throw|while|yield|case|else|for|try|do|if)\\b"
        },
        {
          "name": "keyword.operator.word.tera",
          "match": "\\b(?:instanceof|delete|typeof|void|and|new|not|in|of|or)\\b"
        },
        {
          "name": "constant.language.tera",
          "match": "\\b(?:undefined|false|null|true)\\b"
        },
        {
          "name": "variable.language.tera",
          "match": "\\b(?:super|this)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.tera",
          "match": "\\b(?:GroupedData|DataFrame|boolean|unknown|Column|number|Object|string|String|Tensor|Array|float|Model|bool|List|any|int|Map|Set)\\b"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.tera",
          "match": "\\b(?:optim_config|count_star|compile|count|range|stack|where|expr|avg|cat|col|lit|max|min|sum)\\b"
        },
        {
          "name": "support.function.tera",
          "match": "\\b(?:GradientBoostingClassifier|GradientBoostingRegressor|DecisionTreeClassifier|RandomForestClassifier|DecisionTreeRegressor|RandomForestRegressor|KNeighborsClassifier|KNeighborsRegressor|LogisticRegression|LinearRegression|ElasticNet|GaussianNB|Lasso|Ridge)\\b"
        },
        {
          "name": "support.function.tera",
          "match": "\\b(?:StandardScaler|OneHotEncoder|LabelEncoder|MinMaxScaler|PCA)\\b"
        },
        {
          "name": "support.function.tera",
          "match": "\\b(?:KMeans)\\b"
        },
        {
          "name": "support.function.tera",
          "match": "\\b(?:TimeSeriesSplit|KFold)\\b"
        },
        {
          "name": "support.function.tera",
          "match": "\\b(?:cholesky|lstsq|solve|eigh|pinv|cov|det|inv|svd)\\b"
        },
        {
          "name": "support.function.tera",
          "match": "\\b(?:mean_absolute_error|mean_squared_error|confusion_matrix|accuracy_score|r2_score)\\b"
        },
        {
          "name": "support.function.tera",
          "match": "\\b(?:train_test_split|cross_val_score)\\b"
        },
        {
          "name": "support.function.tera",
          "match": "\\b(?:GridSearchCV)\\b"
        },
        {
          "name": "support.function.tera",
          "match": "\\b(?:normal_cdf|normal_pdf|normal_ppf|chi2_cdf|chi2_pdf|chi2_ppf|f_cdf|f_pdf|f_ppf|t_cdf|t_pdf|t_ppf)\\b"
        },
        {
          "name": "support.function.tera",
          "match": "\\b(?:linear_interp|cubic_spline|lgamma|gamma|erfc|erf)\\b"
        },
        {
          "name": "support.function.tera",
          "match": "\\b(?:ifft|fft|qr)\\b"
        },
        {
          "name": "support.function.tera",
          "match": "\\b(?:chi2_independence|anderson_darling|mann_whitney_u|ks_test_1samp|ks_test_2samp|t_test_paired|dagostino_k2|t_test_1samp|jarque_bera|t_test_ind|chi2_gof)\\b"
        },
        {
          "name": "support.function.tera",
          "match": "\\b(?:durbin_watson|periodogram|ljung_box|pacf|acf)\\b"
        },
        {
          "name": "support.function.tera",
          "match": "\\b(?:rolling_mean|rolling_max|rolling_min|rolling_std|rolling_sum|correlate|polyroots|convolve|polyfit|polyval)\\b"
        },
        {
          "name": "support.function.tera",
          "match": "\\b(?:multivariate_normal|random_exponential|random_uniform|random_normal|random_chi2|random_t)\\b"
        },
        {
          "name": "support.function.tera",
          "match": "\\b(?:min_track_record_length|garch_volatility|cross_sectional|deflated_sharpe|kalman_smoother|garch_forecast|hurst_exponent|mean_reversion|engle_granger|kalman_filter|mean_variance|cusum_events|dynamic_beta|equal_weight|walk_forward|dollar_bars|kyle_lambda|risk_parity|roll_spread|volume_bars|load_quill|long_short|fit_garch|half_life|kpss_test|tick_bars|tick_rule|adf_test|backtest|johansen|momentum|amihud|sharpe|zscore|bsadf|quill|sadf|vpin|hrp|pbo)\\b"
        },
        {
          "name": "support.function.data.tera",
          "match": "\\b(?:register_columns_table|load_tokenizer|TensorDataset|DataLoader|load_model|DataFrame|load_json|read_text|Tokenizer|load_csv)\\b"
        },
        {
          "name": "constant.language.device.tera",
          "match": "\\b(?:webgpu|wasm|cpu|gpu)\\b"
        },
        {
          "name": "constant.language.dtype.tera",
          "match": "\\b(?:bool|f16|f32|f64|i32|i64)\\b"
        },
        {
          "name": "support.function.factory.tera",
          "match": "\\b(?:empty_like|randn_like|zeros_like|full_like|ones_like|linspace|randperm|arange|tensor|empty|randn|zeros|full|ones|eye)\\b"
        },
        {
          "name": "support.class.sequential.tera",
          "match": "\\b(?:Sequential)\\b"
        },
        {
          "name": "support.class.nn-module.tera",
          "match": "\\b(?:AdaptiveAvgPool2d|CrossEntropyLoss|BatchNorm1d|BatchNorm2d|LogSoftmax|AvgPool2d|Embedding|LayerNorm|LeakyReLU|MaxPool2d|LSTMCell|BCELoss|Dropout|Flatten|GRUCell|MSELoss|NLLLoss|Sigmoid|Softmax|Conv1d|Conv2d|Linear|GELU|LSTM|ReLU|SiLU|Tanh|ELU|GRU)\\b"
        },
        {
          "name": "support.class.optimizer.tera",
          "match": "\\b(?:AdamW|Adam|SGD)\\b"
        },
        {
          "name": "support.class.scheduler.tera",
          "match": "\\b(?:CosineAnnealingLR|ReduceLROnPlateau|StepLR)\\b"
        },
        {
          "name": "support.class.trainer.tera",
          "match": "\\b(?:Trainer)\\b"
        },
        {
          "name": "support.class.callback.tera",
          "match": "\\b(?:GradientAccumulationScheduler|LearningRateMonitor|ProgressCallback|ModelCheckpoint|EarlyStopping|Timer)\\b"
        },
        {
          "name": "support.class.logger.tera",
          "match": "\\b(?:ConsoleLogger|CSVLogger)\\b"
        },
        {
          "name": "support.class.metric.tera",
          "match": "\\b(?:MetricCollection|ConfusionMatrix|Precision|Accuracy|F1Score|Recall)\\b"
        },
        {
          "name": "support.class.namespace.tera",
          "match": "\\b(?:chart)\\b"
        },
        {
          "name": "support.function.tera",
          "match": "\\b(?:print)\\b"
        },
        {
          "name": "support.function.tera",
          "match": "\\b(?:log)\\b"
        }
      ]
    },
    "calls": {
      "patterns": [
        {
          "match": "(?<=\\.)\\s*([A-Za-z_$][A-Za-z0-9_$]*)\\s*(?=\\()",
          "captures": {
            "1": {
              "name": "entity.name.function.member.tera"
            }
          }
        },
        {
          "match": "\\b([A-Za-z_$][A-Za-z0-9_$]*)\\s*(?=\\()",
          "captures": {
            "1": {
              "name": "entity.name.function.call.tera"
            }
          }
        },
        {
          "match": "(?<=\\.)\\s*([A-Za-z_$][A-Za-z0-9_$]*)",
          "captures": {
            "1": {
              "name": "variable.other.property.tera"
            }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.compound.tera",
          "match": ">>>=|!==|\\.\\.\\.|\\*\\*=|<<=|===|>>=|>>>|--|-=|->|!=|\\?\\?|\\?\\.|\\*\\*|\\*=|/=|&&|&=|%=|\\^=|\\+\\+|\\+=|<<|<=|==|=>|>=|>>|\\|=|\\|\\|"
        },
        {
          "name": "keyword.operator.tera",
          "match": "\\+|-|\\*|/|%|@|<|>|=|!|&|\\||\\^|~|\\?|:"
        },
        {
          "name": "punctuation.separator.tera",
          "match": "[,.;]"
        },
        {
          "name": "punctuation.section.brackets.tera",
          "match": "[\\[\\](){}]"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.tera",
          "match": "\\b[A-Za-z_$][A-Za-z0-9_$]*\\b"
        }
      ]
    }
  }
}
