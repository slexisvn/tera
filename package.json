{
  "name": "@slexisvn/tera",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "tera": "./dist/cli.js"
  },
  "main": "./dist/index.node.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "browser": "./dist/index.browser.js",
      "default": "./dist/index.node.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "patches"
  ],
  "scripts": {
    "start": "node dist/cli.js",
    "build": "tsup",
    "nb:build": "npm --prefix notebook run build",
    "nb:dev": "npm --prefix notebook run dev",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "postinstall": "patch-package"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.8",
    "puppeteer-core": "^25.1.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@slexisvn/mlfw": "^0.1.2",
    "@slexisvn/quantc": "^0.1.0",
    "@slexisvn/query-engine": "^0.1.2",
    "cli-highlight": "^2.1.11",
    "patch-package": "^8.0.1",
    "terminal-kit": "^3.1.2"
  }
}
